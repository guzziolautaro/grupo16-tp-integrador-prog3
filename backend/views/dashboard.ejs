<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/styles.css">
    <title>Dashboard - Administrador</title>
</head>
<body>
    <nav>
        <h1>Dashboard</h1>
        <div>
            <a href="/admin/logout">
                <button type="button">Cerrar sesión</button>
            </a>
            <a href="/admin/ventas">
                <button type="button">Ventas</button>
            </a>
        </div>
    </nav>
    
    <main>

       <h2>Nuevo Producto</h2>
        
       <form action="/admin/product/new" method="POST" enctype="multipart/form-data">
         <!--<form id="product-form" onsubmit="submitProductForm(event)">-->
            <p>
                <label>Nombre:</label><br>
                <input type="text" name="nombre" required>
            </p>
            <p>
                <label>Categoría:</label><br>
                <input type="text" name="categoria" required>
            </p>
            <p>
                <label>Precio ($):</label><br>
                <input type="number" name="precio" step="0.01" required>
            </p>
            <p>
                <label>Imagen del Producto:</label><br>
                <input type="file" name="image" accept="image/*" required>
            </p>
            <button type="submit">Guardar</button>
        </form>

        <hr>

        <h2>Productos en el Sistema</h2>
        <% if (productos.length === 0) { %>
            <p>Vacio</p>
        <% } else { %>
            <div id="productos">
                <% productos.forEach(prod => { %>
                    <div class="item">
                        <div>
                            <strong><%= prod.nombre %></strong> - 
                                [<%= prod.categoria %>] - 
                                $<%= prod.precio %> 
                                (<%= prod.activo ? 'Activo' : 'Inactivo' %>)
                        </div>
                        <div>
                            <button type="button" onclick="openEditModal('<%= prod.id %>', '<%= prod.nombre %>', '<%= prod.categoria %>', '<%= prod.precio %>')">Edit</button>
        
                            <button type="button" onclick="request('/admin/product/toggle/<%= prod.id %>', 'PUT', 'Estas seguro?')">
                                <%= prod.activo ? 'Desactivar' : 'Activar' %>
                            </button>
        
                            <button type="button" style="color: red;" onclick="request('/admin/product/delete/<%= prod.id %>', 'DELETE', 'Estas seguro?')">
                                Eliminar
                            </button>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>

        <hr>

        <div id="edit-panel">
            <h2>Modificar Producto</h2>
            <form id="edit-form" onsubmit="submitEditForm(event)" enctype="multipart/form-data">
                <input type="hidden" id="edit-id">
                <p>Nombre: <input type="text" id="edit-name" required></p>
                <p>Categoria: <input type="text" id="edit-category" required></p>
                <p>Precio: <input type="number" id="edit-price" step="0.01" required></p>
                <p>Nueva imagen (Optional): <input type="file" id="edit-image" accept="image/*"></p>
                <button type="submit">Guardar</button>
                <button type="button" onclick="document.getElementById('edit-panel').style.display='none'">Cancel</button>
            </form>
        </div>
    </main>

    <script>
    async function request(url, method, message) {
        if (!confirm(message)) return;
        
        try {
            const response = await fetch(url, { method: method });
            if (response.ok) {
                window.location.reload();
            } else {
                alert("Error al procesar la request");
            }
        } catch (err) {
            console.error(err);
        }
    }

    function openEditModal(id, name, category, price) {
        document.getElementById('edit-id').value = id;
        document.getElementById('edit-name').value = name;
        document.getElementById('edit-category').value = category;
        document.getElementById('edit-price').value = price;
        document.getElementById('edit-panel').style.display = 'block';
    }

    async function submitEditForm(event) {
        event.preventDefault();
        const id = document.getElementById('edit-id').value;
        
        const formData = new FormData();
        formData.append('nombre', document.getElementById('edit-name').value);
        formData.append('categoria', document.getElementById('edit-category').value);
        formData.append('precio', document.getElementById('edit-price').value);
        
        const imgFile = document.getElementById('edit-image').files[0];
        if (imgFile) {
            formData.append('image', imgFile); 
        }

        const res = await fetch(`/admin/product/edit/${id}`, {
            method: 'PUT',
            body: formData
        });

        if (res.ok) window.location.reload();
        else alert("Failed to modify product.");
    }
    
    </script>

</body>
</html>