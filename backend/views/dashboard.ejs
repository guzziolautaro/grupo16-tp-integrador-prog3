<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Administrador</title>
</head>
<body>

    <h1>Dashboard</h1>

        <main>
        <h2>Productos en el Sistema</h2>
        <% if (productos.length === 0) { %>
            <p>Vacio</p>
        <% } else { %>
            <ul>
                <% productos.forEach(prod => { %>
                    <li>
                        <strong><%= prod.nombre %></strong> - 
                        [<%= prod.categoria %>] - 
                        $<%= prod.precio %> 
                        (<%= prod.activo ? 'Activo' : 'Inactivo' %>)
                    </li>
                    <button type="button" onclick="request('/admin/producto/toggle/<%= prod.id %>', 'PUT', 'Estas seguro?')">
                        <%= prod.activo ? 'Desactivar' : 'Activar' %>
                    </button>

                    <button type="button" style="color: red;" onclick="request('/admin/producto/eliminar/<%= prod.id %>', 'DELETE', 'Estas seguro?')">
                        Eliminar
                    </button>
                <% }) %>
            </ul>
        <% } %>

        <hr>

        <h2>Nuevo Producto</h2>
        
        <form action="/admin/producto/nuevo" method="POST" enctype="multipart/form-data">
            <p>
                <label>Nombre:</label><br>
                <input type="text" name="nombre" required>
            </p>
            <p>
                <label>Categoría:</label><br>
                <input type="text" name="categoria" required>
            </p>
            <p>
                <label>Precio ($):</label><br>
                <input type="number" name="precio" step="0.01" required>
            </p>
            <p>
                <label>Imagen del Producto:</label><br>
                <input type="file" name="imagen" accept="image/*" required>
            </p>
            <button type="submit">Guardar</button>
        </form>
    </main>

    <script>
    async function request(url, method, message) {
        if (!confirm(message)) return;
        
        try {
            const response = await fetch(url, { method: method });
            if (response.ok) {
                window.location.reload();
            } else {
                alert("Error al procesar la request");
            }
        } catch (err) {
            console.error(err);
        }
    }
    </script>

</body>
</html>