<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Registros - HardwarePoint</title>
</head>
<body>

    <h1>Registros del administrador</h1>

    <nav>
        <a href="/admin/dashboard">Dashboard</a> |
        <a href="/admin/ventas">Ventas</a> |
        <a href="/admin/logout">Cerrar sesión</a>
    </nav>

    <hr>

    <section>
        <h2>10 productos más vendidos</h2>

        <% if (productosMasVendidos.length === 0) { %>
            <p>No hay ventas registradas todavía.</p>
        <% } else { %>
            <table border="1" cellpadding="8" cellspacing="0">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Categoría</th>
                        <th>Cantidad vendida</th>
                        <th>Total recaudado</th>
                    </tr>
                </thead>
                <tbody>
                    <% productosMasVendidos.forEach(item => { %>
                        <tr>
                            <td><%= item.nombre %></td>
                            <td><%= item.categoria %></td>
                            <td><%= item.totalVendido %></td>
                            <td>$<%= item.totalRecaudado %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </section>

    <section>
        <h2>10 ventas más caras</h2>

        <% if (ventasMasCaras.length === 0) { %>
            <p>No hay ventas registradas todavía.</p>
        <% } else { %>
            <table border="1" cellpadding="8" cellspacing="0">
                <thead>
                    <tr>
                        <th>ID Venta</th>
                        <th>Cliente</th>
                        <th>Fecha</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    <% ventasMasCaras.forEach(venta => { %>
                        <tr>
                            <td><%= venta.id %></td>
                            <td><%= venta.nombreCliente %></td>
                            <td><%= venta.fecha %></td>
                            <td>$<%= venta.total %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </section>

    <section>
        <h2>Logs de inicio de sesión</h2>
        <p>Acá se mostrarán los registros de acceso de administradores.</p>
    </section>

    <section>
        <h2>Estadísticas adicionales</h2>
        <p>Acá se mostrarán dos estadísticas extra.</p>
    </section>

</body>
</html>