<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Registros - HardwarePoint</title>
</head>
<body>

    <h1>Registros del administrador</h1>

    <nav>
        <a href="/admin/dashboard">Dashboard</a> |
        <a href="/admin/ventas">Ventas</a> |
        <a href="/admin/logout">Cerrar sesión</a>
    </nav>

    <hr>

    <section>
        <h2>10 productos más vendidos</h2>

        <% if (productosMasVendidos.length === 0) { %>
            <p>No hay ventas registradas todavía.</p>
        <% } else { %>
            <table border="1" cellpadding="8" cellspacing="0">
                <thead>
                    <tr>
                        <th>Producto</th>
                        <th>Categoría</th>
                        <th>Cantidad vendida</th>
                        <th>Total recaudado</th>
                    </tr>
                </thead>
                <tbody>
                    <% productosMasVendidos.forEach(item => { %>
                        <tr>
                            <td><%= item.nombre %></td>
                            <td><%= item.categoria %></td>
                            <td><%= item.totalVendido %></td>
                            <td>$<%= item.totalRecaudado %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </section>

    <section>
        <h2>10 ventas más caras</h2>

        <% if (ventasMasCaras.length === 0) { %>
            <p>No hay ventas registradas todavía.</p>
        <% } else { %>
            <table border="1" cellpadding="8" cellspacing="0">
                <thead>
                    <tr>
                        <th>ID Venta</th>
                        <th>Cliente</th>
                        <th>Fecha</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    <% ventasMasCaras.forEach(venta => { %>
                        <tr>
                            <td><%= venta.id %></td>
                            <td><%= venta.nombreCliente %></td>
                            <td><%= venta.fecha %></td>
                            <td>$<%= venta.total %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </section>

    <section>
        <h2>Logs de inicio de sesión</h2>

        <% if (loginLogs.length === 0) { %>
            <p>No hay inicios de sesión registrados todavía.</p>
        <% } else { %>
            <table border="1" cellpadding="8" cellspacing="0">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>IP</th>
                        <th>Navegador</th>
                        <th>Fecha y hora</th>
                    </tr>
                </thead>
                <tbody>
                    <% loginLogs.forEach(log => { %>
                        <tr>
                            <td><%= log.email %></td>
                            <td><%= log.ip %></td>
                            <td><%= log.userAgent %></td>
                            <td><%= log.fechaHora.toLocaleString('es-AR') %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </section>

    <section>
        <h2>Total recaudado por categoría</h2>

        <% if (recaudadoPorCategoria.length === 0) { %>
            <p>No hay datos suficientes para mostrar esta estadística.</p>
        <% } else { %>
            <table border="1" cellpadding="8" cellspacing="0">
                <thead>
                    <tr>
                        <th>Categoría</th>
                        <th>Cantidad vendida</th>
                        <th>Total recaudado</th>
                    </tr>
                </thead>
                <tbody>
                    <% recaudadoPorCategoria.forEach(item => { %>
                        <tr>
                            <td><%= item.categoria %></td>
                            <td><%= item.totalVendido %></td>
                            <td>$<%= item.totalRecaudado %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        <% } %>
    </section>

    <section>
        <h2>Resumen general de ventas</h2>

        <table border="1" cellpadding="8" cellspacing="0">
            <thead>
                <tr>
                    <th>Total de ventas</th>
                    <th>Productos vendidos</th>
                    <th>Recaudación total</th>
                    <th>Promedio por venta</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><%= resumenGeneral.totalVentas %></td>
                    <td><%= resumenGeneral.productosVendidos %></td>
                    <td>$<%= resumenGeneral.recaudacionTotal %></td>
                    <td>$<%= Number(resumenGeneral.promedioPorVenta).toFixed(2) %></td>
                </tr>
            </tbody>
        </table>
    </section>

</body>
</html>